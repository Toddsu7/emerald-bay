# Emerald Bay Lake App — environment.
# Copy to .env.local and fill in. NEVER commit .env.local.
# Project ref: heybszfdbvavedjkgggb

# ── Supabase ────────────────────────────────────────────────────────────────
# Public — safe to expose to the browser (anon key is RLS-scoped).
NEXT_PUBLIC_SUPABASE_URL=https://heybszfdbvavedjkgggb.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — the service-role key BYPASSES RLS. Never expose to the client.
# Used by the import script and by cron/sweep + admin server actions.
SUPABASE_SERVICE_ROLE_KEY=

# ── Cron / sweep (§5) ────────────────────────────────────────────────────────
# Shared secret the external pinger (cron-job.org) sends to /api/cron/sweep.
CRON_SECRET=

# ── Notifications (§9) — dormant until keyed ─────────────────────────────────
# Twilio SMS (LAUNCH/PASS at the ramp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:board@emeraldbay.example

# ── App ──────────────────────────────────────────────────────────────────────
# Public base URL, used in magic-link + SMS deep links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
